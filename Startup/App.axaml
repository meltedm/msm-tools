<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sty="using:FluentAvalonia.Styling"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:uip="using:FluentAvalonia.UI.Controls.Primitives"
             xmlns:avaloniaMica="clr-namespace:Startup"
             x:Class="Startup.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <sty:FluentAvaloniaTheme PreferUserAccentColor="True" />
        <Style Selector=":is(Window)">
            <Setter Property="(avaloniaMica:UiGlobal.TransparencyEnabled)" Value="True" />
        </Style>
        <Style Selector=":is(Window)">
            <Setter Property="Background" Value="{DynamicResource UIWindowBackgroundBrushInactive}" />
        </Style>
        <Style Selector=":is(Window)[ActualTransparencyLevel=Mica]">
            <Setter Property="Background" Value="#00000000" />
        </Style>
    </Application.Styles>
</Application>